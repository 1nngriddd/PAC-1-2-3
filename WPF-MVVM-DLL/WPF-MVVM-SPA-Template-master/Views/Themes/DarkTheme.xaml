<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════
         COLORS  ── Paleta fosca coherent amb el LightTheme
         Mateixa família terrosa/olivàcia, però invertida:
         els fons passen a verd quasi-negre i el text a crema clar.
    ══════════════════════════════════════════════════ -->
    <Color x:Key="ColorFondo"        >#0F1208</Color>  <!-- fons principal (quasi negre olivaci) -->
    <Color x:Key="ColorPanel"        >#1C2209</Color>  <!-- cards i panells interiors -->
    <Color x:Key="ColorCapcalera"    >#090D04</Color>  <!-- sidebar i capçaleres de taula -->
    <Color x:Key="ColorAccent"       >#B99668</Color>  <!-- or/ambre — idèntic al CremaFosc del light -->
    <Color x:Key="ColorTextPrincipal">#DCC9A7</Color>  <!-- text principal (crema clar) -->
    <Color x:Key="ColorTextSecundari">#8A9A6E</Color>  <!-- text secundari / labels -->
    <Color x:Key="ColorBorde"        >#3A4415</Color>  <!-- vores i separadors -->
    <Color x:Key="ColorHover"        >#2A3A12</Color>  <!-- fons hover de files i botons -->
    <Color x:Key="ColorSeleccionat"  >#4A5820</Color>  <!-- estat seleccionat -->
    <Color x:Key="ColorAltRow"       >#161C08</Color>  <!-- files alternes del DataGrid -->
    <Color x:Key="ColorInput"        >#141A07</Color>  <!-- fons dels TextBox -->
    <Color x:Key="ColorPerill"       >#C0392B</Color>  <!-- vermell perill (Cancel·lar) -->

    <!-- ══════════════════════════════════════════════════
         BRUSHES
    ══════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BrushFondo"         Color="{StaticResource ColorFondo}"/>
    <SolidColorBrush x:Key="BrushPanel"         Color="{StaticResource ColorPanel}"/>
    <SolidColorBrush x:Key="BrushCapcalera"     Color="{StaticResource ColorCapcalera}"/>
    <SolidColorBrush x:Key="BrushAccent"        Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushTextPrincipal" Color="{StaticResource ColorTextPrincipal}"/>
    <SolidColorBrush x:Key="BrushTextSecundari" Color="{StaticResource ColorTextSecundari}"/>
    <SolidColorBrush x:Key="BrushBorde"         Color="{StaticResource ColorBorde}"/>
    <SolidColorBrush x:Key="BrushHover"         Color="{StaticResource ColorHover}"/>
    <SolidColorBrush x:Key="BrushSeleccionat"   Color="{StaticResource ColorSeleccionat}"/>
    <SolidColorBrush x:Key="BrushAltRow"        Color="{StaticResource ColorAltRow}"/>
    <SolidColorBrush x:Key="BrushInput"         Color="{StaticResource ColorInput}"/>

    <!-- Mantenim les claus del LightTheme que el codi de la DLL espera -->
    <SolidColorBrush x:Key="BrushCremaFosc"  Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushCrema"      Color="{StaticResource ColorPanel}"/>
    <SolidColorBrush x:Key="BrushTextCrema"  Color="{StaticResource ColorTextPrincipal}"/>
    <SolidColorBrush x:Key="BrushVerdFosc"   Color="{StaticResource ColorCapcalera}"/>
    <SolidColorBrush x:Key="BrushVerd"       Color="{StaticResource ColorTextSecundari}"/>
    <SolidColorBrush x:Key="BrushVerdClar"   Color="{StaticResource ColorHover}"/>
    <SolidColorBrush x:Key="BrushVerdHover"  Color="{StaticResource ColorSeleccionat}"/>
    <SolidColorBrush x:Key="BrushCremaClar"  Color="{StaticResource ColorBorde}"/>
    <SolidColorBrush x:Key="BrushVerdClick"  Color="{StaticResource ColorSeleccionat}"/>
    <SolidColorBrush x:Key="BrushFestuc"     Color="{StaticResource ColorAltRow}"/>
    <SolidColorBrush x:Key="BrushCremaPalido" Color="{StaticResource ColorPanel}"/>

    <!-- ══════════════════════════════════════════════════
         DYNAMIC RESOURCE ALIASES  (compatibilitat Projecte A)
    ══════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="MainBackground"      Color="{StaticResource ColorFondo}"/>
    <SolidColorBrush x:Key="SidebarBackground"   Color="{StaticResource ColorCapcalera}"/>
    <SolidColorBrush x:Key="PrimaryTextColor"    Color="{StaticResource ColorTextPrincipal}"/>
    <SolidColorBrush x:Key="ValidationTextBrush" Color="{StaticResource ColorTextSecundari}"/>
    <SolidColorBrush x:Key="BackgroundBrush"     Color="{StaticResource ColorInput}"/>
    <SolidColorBrush x:Key="BorderBrush"         Color="{StaticResource ColorBorde}"/>
    <SolidColorBrush x:Key="TextBrush"           Color="{StaticResource ColorTextPrincipal}"/>

    <!-- ══════════════════════════════════════════════════
         TEXTBOX
    ══════════════════════════════════════════════════ -->
    <Style TargetType="TextBox">
        <Setter Property="Background"               Value="{StaticResource BrushInput}"/>
        <Setter Property="BorderBrush"              Value="{StaticResource BrushBorde}"/>
        <Setter Property="Foreground"               Value="{StaticResource BrushTextPrincipal}"/>
        <Setter Property="CaretBrush"               Value="{StaticResource BrushAccent}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Padding"                  Value="8,6"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="FontFamily"               Value="Cambria"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="false"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{StaticResource BrushTextSecundari}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{StaticResource BrushAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════
         DATEPICKER
    ══════════════════════════════════════════════════ -->
    <Style x:Key="ModernDatePickerStyle" TargetType="DatePicker">
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="FontFamily"          Value="Cambria"/>
        <Setter Property="Foreground"          Value="{StaticResource BrushTextPrincipal}"/>
        <Setter Property="Background"          Value="{StaticResource BrushInput}"/>
        <Setter Property="BorderBrush"         Value="{StaticResource BrushBorde}"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="Padding"             Value="8"/>
        <Setter Property="Margin"              Value="0,5"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- ══════════════════════════════════════════════════
         DATAGRID
    ══════════════════════════════════════════════════ -->
    <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
        <Setter Property="Background"               Value="{StaticResource BrushPanel}"/>
        <Setter Property="RowBackground"            Value="{StaticResource BrushPanel}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource BrushAltRow}"/>
        <Setter Property="BorderBrush"              Value="{StaticResource BrushBorde}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushBorde}"/>
        <Setter Property="FontFamily"               Value="Cambria"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="Foreground"               Value="{StaticResource BrushTextPrincipal}"/>
        <Setter Property="RowHeaderWidth"           Value="0"/>
        <Setter Property="SelectionMode"            Value="Single"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{StaticResource BrushCapcalera}"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushAccent}"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="FontFamily"      Value="Georgia"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushBorde}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushTextPrincipal}"/>
        <Setter Property="FontFamily"      Value="Cambria"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="4,2"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushSeleccionat}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════════════════ -->
    <Style x:Key="ModernSidebarStyle" TargetType="ListBoxItem">
        <Setter Property="Foreground"                 Value="{StaticResource BrushTextSecundari}"/>
        <Setter Property="Background"                 Value="{StaticResource BrushCapcalera}"/>
        <Setter Property="Margin"                     Value="4,3"/>
        <Setter Property="Padding"                    Value="10,8"/>
        <Setter Property="BorderThickness"            Value="1"/>
        <Setter Property="FontSize"                   Value="14"/>
        <Setter Property="FontWeight"                 Value="Normal"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="FontFamily"                 Value="Georgia"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="BB"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BrushBorde}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalAlignment}"
                            TextBlock.FontFamily="{TemplateBinding FontFamily}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BB" Property="Background"
                                    Value="{StaticResource BrushHover}"/>
                            <Setter TargetName="BB" Property="BorderBrush"
                                    Value="{StaticResource BrushTextSecundari}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="BB" Property="Background"
                                    Value="{StaticResource BrushSeleccionat}"/>
                            <Setter TargetName="BB" Property="BorderBrush"
                                    Value="{StaticResource BrushAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════
         LABEL
    ══════════════════════════════════════════════════ -->
    <Style x:Key="ModernLabelStyle" TargetType="Label">
        <Setter Property="FontSize"          Value="14"/>
        <Setter Property="FontFamily"        Value="Cambria"/>
        <Setter Property="Foreground"        Value="{StaticResource BrushTextSecundari}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin"            Value="0,5,10,0"/>
    </Style>

    <!-- ══════════════════════════════════════════════════
         BOTONS ── PRIMARY
    ══════════════════════════════════════════════════ -->
    <Style x:Key="ModernPrimaryButtonStyle" TargetType="Button">
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="FontFamily"      Value="Georgia"/>
        <Setter Property="Padding"         Value="16,8"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushAccent}"/>
        <Setter Property="Background"      Value="{StaticResource BrushCapcalera}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushBorde}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Margin"          Value="5,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{StaticResource BrushHover}"/>
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{StaticResource BrushAccent}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{StaticResource BrushSeleccionat}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SECONDARY -->
    <Style x:Key="ModernSecundaryButtonStyle" TargetType="Button"
           BasedOn="{StaticResource ModernPrimaryButtonStyle}">
        <Setter Property="Background"  Value="{StaticResource BrushPanel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushTextSecundari}"/>
    </Style>

    <!-- DANGER -->
    <Style x:Key="ModernDangerButtonStyle" TargetType="Button">
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="FontFamily"      Value="Georgia"/>
        <Setter Property="Padding"         Value="16,8"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="Background"      Value="{StaticResource ColorPerill}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Margin"          Value="5,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#922B21"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- EDIT ICON BUTTON -->
    <Style x:Key="ModernEditButtonStyle" TargetType="Button">
        <Setter Property="Width"           Value="30"/>
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="4"/>
        <Setter Property="Margin"          Value="0,0,6,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{StaticResource BrushHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{StaticResource BrushSeleccionat}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

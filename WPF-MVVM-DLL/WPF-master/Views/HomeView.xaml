<UserControl x:Class="WPF_MVVM_SPA_Template.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource MainBackground}">

    <Grid Background="{DynamicResource MainBackground}">

        <Border Background="{StaticResource BrushCremaClar}"
                Margin="40"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MinWidth="480"
                Padding="60,50">

            <StackPanel HorizontalAlignment="Center">

                <!-- Títol principal -->
                <TextBlock Text="iCustomer"
                           FontSize="52"
                           FontWeight="Bold"
                           FontFamily="Georgia"
                           Foreground="{StaticResource BrushVerdFosc}"
                           HorizontalAlignment="Center"/>

                <!-- Línia decorativa -->
                <Border Background="{StaticResource BrushVerd}"
                        Height="3"
                        Width="320"
                        Margin="0,14,0,20"/>

                <!-- Subtítols -->
                <TextBlock Text="Benvingut al gestor de clients"
                           FontSize="18"
                           FontFamily="Cambria"
                           Foreground="{StaticResource BrushVerd}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Selecciona una opció del menú lateral per començar."
                           FontSize="14"
                           FontFamily="Cambria"
                           Foreground="{StaticResource BrushVerd}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>

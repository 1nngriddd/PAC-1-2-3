<Window x:Class="WPF_MVVM_SPA_Template.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="iCustomer" Height="600" Width="1050"
        Background="{DynamicResource MainBackground}"
        TextElement.Foreground="{DynamicResource PrimaryTextColor}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>

        <!-- SIDEBAR -->
        <ListBox DockPanel.Dock="Left" Width="150"
                 Background="{DynamicResource SidebarBackground}"
                 BorderThickness="0"
                 SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}">
            <ListBoxItem Content="Inici"        FontSize="16" Padding="10"
                         Style="{StaticResource ModernSidebarStyle}"/>
            <ListBoxItem Content="Clients"      FontSize="16" Padding="10"
                         Style="{StaticResource ModernSidebarStyle}"/>
            <ListBoxItem Content="Configuració" FontSize="16" Padding="10"
                         Style="{StaticResource ModernSidebarStyle}"/>
        </ListBox>

        <!-- CONTINGUT PRINCIPAL + OVERLAY -->
        <Grid Name="MainContent" Background="{DynamicResource MainBackground}">

            <!-- Vista activa -->
            <ContentControl Content="{Binding CurrentView}" Margin="10"
                            Panel.ZIndex="0"/>

            <!-- MODAL OVERLAY: fons fosc semitransparent que tapa la vista -->
            <Grid Panel.ZIndex="10"
                  Background="#CC000000"
                  Visibility="{Binding IsPopupVisible, Converter={StaticResource BoolToVis}}">

                <!-- Targeta del popup: fons crema completament opac -->
                <Border Width="420"
                        CornerRadius="12"
                        BorderThickness="2"
                        BorderBrush="#B99668"
                        Background="#EDE2CC"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Padding="32,28"
                        Panel.ZIndex="20">

                    <Grid>

                        <!-- Botó X tancar -->
                        <Button Content="✕"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Width="28" Height="28"
                                FontSize="11"
                                Margin="0,-6,-6,0"
                                Padding="0"
                                Command="{Binding ClosePopupCommand}"
                                Style="{StaticResource ModernPrimaryButtonStyle}"/>

                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0">

                            <!-- Trofeu -->
                            <TextBlock Text="🏆"
                                       FontSize="42"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>

                            <!-- Etiqueta fixa -->
                            <TextBlock Text="Millor Client"
                                       FontSize="12"
                                       FontFamily="Cambria"
                                       Foreground="#697875"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>

                            <!-- Nom del client -->
                            <TextBlock Text="{Binding PopupTitle}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       FontFamily="Georgia"
                                       Foreground="#242C0A"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <!-- Línia decorativa -->
                            <Border Height="1" Width="260"
                                    Background="#B99668"
                                    Margin="0,0,0,12"/>

                            <!-- Missatge facturació -->
                            <TextBlock Text="{Binding PopupMessage}"
                                       FontSize="14"
                                       FontFamily="Cambria"
                                       Foreground="#242C0A"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,22"/>

                            <!-- Botó tancar inferior -->
                            <Button Content="Tancar"
                                    Command="{Binding ClosePopupCommand}"
                                    Style="{StaticResource ModernPrimaryButtonStyle}"
                                    Width="140" Height="38"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </DockPanel>
</Window>

<Window x:Class="TestMyControls.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mydll="clr-namespace:WPF_DemoDDL;assembly=WPF-DemoDDL"
        Title="Dades del Client (Proves)" Height="600" Width="700"
        Background="#FFFFFF"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dades del Client" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,30" Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Nom -->
            <TextBlock Text="Nom:" Style="{StaticResource LabelStyle}" Grid.Row="0" Grid.Column="0" Margin="0,0,0,15"/>
            <mydll:MinLengthTextBox MinLength="2" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15" MinHeight="38"/>

            <!-- Cognoms (using standard TextBox to test implicit style) -->
            <TextBlock Text="Cognoms:" Style="{StaticResource LabelStyle}" Grid.Row="1" Grid.Column="0" Margin="0,0,0,15"/>
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,15" MinHeight="38"/>

            <!-- DNI -->
            <TextBlock Text="DNI:" Style="{StaticResource LabelStyle}" Grid.Row="2" Grid.Column="0" Margin="0,0,0,15"/>
            <mydll:DNITextBox Placeholder="Ex: 12345678Z" Grid.Row="2" Grid.Column="1" Margin="0,0,0,15" MinHeight="38"/>

            <!-- Email -->
            <TextBlock Text="Email:" Style="{StaticResource LabelStyle}" Grid.Row="3" Grid.Column="0" Margin="0,0,0,15"/>
            <mydll:EmailTextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,15" MinHeight="38"/>

            <!-- Telèfon -->
            <TextBlock Text="Telèfon:" Style="{StaticResource LabelStyle}" Grid.Row="4" Grid.Column="0" Margin="0,0,0,15"/>
            <mydll:PhoneTextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,15" MinHeight="38"/>

            <!-- Data Alta -->
            <TextBlock Text="Data Alta:" Style="{StaticResource LabelStyle}" Grid.Row="5" Grid.Column="0" Margin="0,0,0,15"/>
            <DatePicker Grid.Row="5" Grid.Column="1" Margin="0,0,0,15" Height="38" HorizontalAlignment="Left" Width="200" />
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="Guardar" Style="{StaticResource SaveButtonStyle}" Width="120" Height="42" Margin="0,0,15,0"/>
            <Button Content="Cancel·lar" Style="{StaticResource CancelButtonStyle}" Width="120" Height="42"/>
        </StackPanel>
    </Grid>
</Window>
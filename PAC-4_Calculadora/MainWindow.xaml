<Window x:Class="PAC_4_Calculadora.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PAC_4_Calculadora"
        mc:Ignorable="d"
        Title="Calculadora Ferrari"
        Height="540" Width="370"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>


        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="FontSize"        Value="22"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Margin"          Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="4">
                            
                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                                  BlurRadius="8"
                                                  ShadowDepth="2"
                                                  Opacity="0.35"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="NumButtonStyle" TargetType="Button"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#C4CBCB"/>
            <Setter Property="Foreground" Value="#3B3736"/>
        </Style>

        
        <Style x:Key="OpButtonStyle" TargetType="Button"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#AEA4A2"/>
            <Setter Property="Foreground" Value="#3B3736"/>
        </Style>

        <Style x:Key="ClearButtonStyle" TargetType="Button"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#3B3736"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="EqualButtonStyle" TargetType="Button"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#DCB318"/>
            <Setter Property="Foreground" Value="#3B3736"/>
        </Style>
    </Window.Resources>


    <Border CornerRadius="20"
        Margin="12"
        Background="#DE0202"
        BorderBrush="#3B3736"
        BorderThickness="3"
        MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                          BlurRadius="20"
                          ShadowDepth="0"
                          Opacity="0.4"/>
        </Border.Effect>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="125"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,4,0,10">
                <TextBlock Text="🐎 CALCULADORA"
                       FontFamily="Segoe UI"
                       FontWeight="Bold"
                       FontSize="14"
                       Foreground="#DCB318"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                <Button Content="✕"
                    HorizontalAlignment="Right"
                    Width="28" Height="28"
                    Background="Transparent"
                    Foreground="#DCB318"
                    BorderThickness="0"
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand"
                    Click="Close_Click"/>
            </Grid>

            <Border Grid.Row="1" Background="#3B3736" CornerRadius="14"
                Margin="0,0,0,10" Padding="14,8">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10"
                                  ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <TextBlock x:Name="Display"
                       Text="0"
                       FontSize="45"
                       FontFamily="Consolas"
                       FontWeight="Bold"
                       Foreground="#DCB318"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"/>
            </Border>

            <UniformGrid Grid.Row="2" Rows="4" Columns="4">

                <Button Content="7" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="7"/>
                <Button Content="8" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="8"/>
                <Button Content="9" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="9"/>
                <Button Content="÷" Style="{StaticResource OpButtonStyle}"  Click="Operation_Click" Tag="/"/>

                <Button Content="4" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="4"/>
                <Button Content="5" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="5"/>
                <Button Content="6" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="6"/>
                <Button Content="×" Style="{StaticResource OpButtonStyle}"  Click="Operation_Click" Tag="*"/>

                
                <Button Content="1" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="1"/>
                <Button Content="2" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="2"/>
                <Button Content="3" Style="{StaticResource NumButtonStyle}" Click="Value_Click"     Tag="3"/>
                <Button Content="−" Style="{StaticResource OpButtonStyle}"  Click="Operation_Click" Tag="-"/>

                
                <Button Content="C" Style="{StaticResource ClearButtonStyle}" Click="Clear_Click"/>
                <Button Content="0" Style="{StaticResource NumButtonStyle}"   Click="Value_Click"     Tag="0"/>
                <Button Content="=" Style="{StaticResource EqualButtonStyle}" Click="Result_Click"/>
                <Button Content="+" Style="{StaticResource OpButtonStyle}"    Click="Operation_Click" Tag="+"/>

            </UniformGrid>
        </Grid>
    </Border>
</Window>